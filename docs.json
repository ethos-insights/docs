{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Trek Documentation",
  "description": "Step-by-step guides for everything you want to do in Trek",
  "colors": {
    "primary": "#1F33CC",
    "light": "#6d7cf3",
    "dark": "#051697"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        },
        {
          "anchor": "Changelog",
          "icon": "scroll-text",
          "href": "https://www.mintlify.com/docs/changelog"
        },
        {
          "anchor": "Help",
          "icon": "life-buoy",
          "href": "https://www.mintlify.com/docs/contact-support"
        }
      ]
    },
    "directory": "card",
    "groups": [
      {
        "group": "Platform",
        "icon": "layers",
        "expanded": true,
        "pages": [
          "platform/quickstart",
          "platform/key-concepts",
          "platform/configuration/settings",
          "platform/configuration/user-management",
          "platform/administration/roles-permissions"
        ]
      },
      {
        "group": "Analytics",
        "icon": "chart-bar",
        "expanded": true,
        "pages": [
          "analytics/quickstart",
          "analytics/connect-data",
          "analytics/dashboards/create-dashboard",
          "analytics/reports/scheduled-reports"
        ]
      },
      {
        "group": "Integrations",
        "icon": "plug",
        "expanded": true,
        "pages": [
          "integrations/quickstart",
          "integrations/authentication",
          "integrations/connectors/crm",
          "integrations/webhooks/configure"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/yourcompany",
      "linkedin": "https://linkedin.com/company/yourcompany"
    }
  },
  "appearance": {
    "default": "system"
  },
  "fonts": {
    "family": "Open Sans",
    "weight": 400
  }
}

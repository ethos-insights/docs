{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Trek Documentation",
  "description": "Step-by-step guides for everything you want to do in Trek",
  "colors": {
    "primary": "#1F33CC",
    "light": "#6d7cf3",
    "dark": "#051697"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        }
      ]
    },
    "directory": "card",
    "groups": [
      {
        "group": "Getting Started",
        "pages": [
          "getting-started/student-rostering-requirements",
          "getting-started/school-system-integrations",
          "getting-started/technical-requirements"
        ]
      },
      {
        "group": "Teacher Guide",
        "pages": [
          "teacher-guide/project-based-learning-support",
          "teacher-guide/tools-for-differentiated-instruction",
          "teacher-guide/using-trek-for-math-instruction",
          "teacher-guide/best-practices-for-rolling-out-trek-to-students",
          "teacher-guide/proofreading-options-in-trek"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "/logo/logo.png"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/yourcompany",
      "linkedin": "https://linkedin.com/company/yourcompany"
    }
  },
  "appearance": {
    "default": "system"
  },
  "fonts": {
    "family": "Open Sans",
    "weight": 400
  }
}
